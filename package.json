{
  "name": "decision-tracer-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "generate:analysis-prompt": "openui generate ./src/library.ts --export analysisLibrary --prompt-options analysisPromptOptions --out ./src/generated/analysis-system-prompt.txt",
    "dev": "npm run generate:analysis-prompt && vite",
    "test:graph": "node --test --experimental-strip-types ./tests/*.test.ts",
    "build": "npm run generate:analysis-prompt && tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@openuidev/cli": "^0.0.6",
    "@openuidev/react-headless": "^0.7.11",
    "@openuidev/react-lang": "^0.1.4",
    "@tanstack/react-query": "^5.90.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.1",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  }
}
